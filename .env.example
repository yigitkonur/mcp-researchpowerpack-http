PORT=3000
HOST=127.0.0.1
#ALLOWED_ORIGINS=          # Comma-separated origins for CORS / host validation
#MCP_URL=                  # Public MCP URL fallback for production origin protection
#REDIS_URL=                # Redis-backed sessions + workflow state (unset = in-memory)

# ── Provider API Keys (each enables its tools) ──
SERPER_API_KEY=             # web-search, search-reddit
REDDIT_CLIENT_ID=           # get-reddit-post
REDDIT_CLIENT_SECRET=       # get-reddit-post
SCRAPEDO_API_KEY=           # scrape-links

# ── LLM (AI extraction + search classification + raw refine suggestions) ──
# Only LLM_API_KEY is required. Everything else has sensible defaults.
LLM_API_KEY=                # Any OpenAI-compatible provider
#LLM_BASE_URL=https://openrouter.ai/api/v1   # Default: OpenRouter-compatible
#LLM_MODEL=openai/gpt-5.4-mini               # Default model for extraction + classification
#LLM_MAX_TOKENS=8000                         # Output token limit (range: 1000-32000)
#LLM_REASONING=low                           # none | low | medium | high
#LLM_CONCURRENCY=50                          # Parallel LLM calls (default: 50, range: 1-200)

# ── Per-provider concurrency overrides ──
#CONCURRENCY_SEARCH=50
#CONCURRENCY_SCRAPER=50
#CONCURRENCY_REDDIT=50

# ── Eval harness ──
EVAL_MCP_URL=http://localhost:3000/mcp
EVAL_MODEL=gpt-4.1-mini
EVAL_API_KEY=

# Legacy env names still work, but prefer the LLM_* names above:
# OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# LLM_EXTRACTION_API_KEY=
# LLM_EXTRACTION_BASE_URL=https://openrouter.ai/api/v1
# LLM_EXTRACTION_MODEL=
# LLM_EXTRACTION_MAX_TOKENS=
# LLM_EXTRACTION_REASONING=
# LLM_EXTRACTION_CONCURRENCY=
