PORT=3000
HOST=127.0.0.1
MCP_URL=
ALLOWED_ORIGINS=
REDIS_URL=

# Local development can leave MCP_URL and ALLOWED_ORIGINS empty.
# Production can boot without ALLOWED_ORIGINS, but host validation stays disabled until you set it.
# For Manufact Cloud, deploy once to learn the assigned URL, then set ALLOWED_ORIGINS to that URL.
# Example:
# HOST=0.0.0.0
# ALLOWED_ORIGINS=https://app.example.com,https://inspector.mcp-use.com

SERPER_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
SCRAPEDO_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

RESEARCH_MODEL=x-ai/grok-4-fast
RESEARCH_FALLBACK_MODEL=google/gemini-2.5-flash
LLM_EXTRACTION_MODEL=openai/gpt-oss-120b:nitro
DEFAULT_REASONING_EFFORT=high
DEFAULT_MAX_URLS=100
API_TIMEOUT_MS=1800000

# LLM Extraction (optional overrides — defaults to OpenRouter settings above)
#LLM_EXTRACTION_API_KEY=
#LLM_EXTRACTION_BASE_URL=https://openrouter.ai/api/v1
