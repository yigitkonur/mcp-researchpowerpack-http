PORT=3000
HOST=127.0.0.1
#ALLOWED_ORIGINS=          # Comma-separated origins for CORS (unset = no restriction)
#REDIS_URL=                # Redis-backed sessions (unset = in-memory)

# ── Provider API Keys (each enables its tools) ──
SERPER_API_KEY=             # web-search, search-reddit
REDDIT_CLIENT_ID=           # get-reddit-post
REDDIT_CLIENT_SECRET=       # get-reddit-post
SCRAPEDO_API_KEY=           # scrape-links

# ── LLM (AI extraction + search classification) ──
# Only LLM_API_KEY is required. Everything else has sensible defaults.
LLM_API_KEY=                # Any OpenAI-compatible provider
#LLM_BASE_URL=https://openrouter.ai/api/v1   # Default: OpenRouter
#LLM_MODEL=openai/gpt-5.4-mini               # Default: openai/gpt-5.4-mini
#LLM_MAX_TOKENS=8000       # Output token limit (range: 1000-32000)
#LLM_REASONING=low         # none | low | medium | high
#LLM_CONCURRENCY=50              # Parallel LLM calls (default: 50, range: 1-200)
#CONCURRENCY_SEARCH=50           # Parallel search API calls (default: 50, range: 1-200)
#CONCURRENCY_SCRAPER=50          # Parallel scrape calls (default: 50, range: 1-200)
#CONCURRENCY_REDDIT=50           # Parallel Reddit API calls (default: 50, range: 1-200)
