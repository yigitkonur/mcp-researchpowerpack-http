{
  "name": "mcp-researchpowerpack-http",
  "version": "4.1.1",
  "description": "The ultimate research MCP toolkit: Reddit mining, web search with CTR aggregation, and intelligent web scraping - all in one modular package",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-researchpowerpack-http": "dist/index.js",
    "mcp-research-powerpack-http": "dist/index.js"
  },
  "files": [
    "dist",
    "!dist/tests"
  ],
  "scripts": {
    "build": "mcp-use build",
    "dev": "mcp-use dev",
    "start": "mcp-use start",
    "deploy": "mcp-use deploy",
    "inspect": "npx @mcp-use/inspector --url http://localhost:3000/mcp",
    "typecheck": "tsc --noEmit",
    "test": "pnpm test:http",
    "test:http": "tsx tests/http-server.ts",
    "prepublishOnly": "pnpm build && pnpm typecheck"
  },
  "keywords": [
    "mcp",
    "research",
    "reddit",
    "serper",
    "search",
    "ai",
    "model-context-protocol",
    "web-scraping",
    "claude",
    "anthropic",
    "openrouter",
    "scraping",
    "research-powerpack",
    "http-mcp"
  ],
  "author": "Yiğit Konur <yigit35@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yigitkonur/mcp-researchpowerpack-http.git"
  },
  "homepage": "https://github.com/yigitkonur/mcp-researchpowerpack-http#readme",
  "bugs": {
    "url": "https://github.com/yigitkonur/mcp-researchpowerpack-http/issues"
  },
  "dependencies": {
    "mcp-use": "1.22.0",
    "openai": "^4.77.0",
    "redis": "^5.11.0",
    "turndown": "^7.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@mcp-use/cli": "2.20.0",
    "@types/node": "^22.0.0",
    "@types/turndown": "^5.0.6",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
